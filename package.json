{
  "name": "sowel",
  "version": "1.2.10",
  "description": "Sowel — Home automation engine powered by MQTT",
  "author": "Marc Chachereau <marc.chachereau@gmail.com>",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch --exclude 'plugins/**' src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.{json,md,js}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{json,md,js}\"",
    "validate": "npm run typecheck && npm run lint && npm run format:check && npm run test && npm run validate:ui",
    "validate:ui": "cd ui && npm run lint && npm run typecheck",
    "prepare": "husky"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.0.1",
    "@influxdata/influxdb-client": "^1.35.0",
    "@types/archiver": "^7.0.0",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^11.7.0",
    "croner": "^10.0.1",
    "dockerode": "^4.0.10",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mqtt": "^5.15.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "pino-roll": "^4.0.0",
    "suncalc": "^1.9.0",
    "tz-lookup": "^6.1.25"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/adm-zip": "^0.5.8",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/dockerode": "^4.0.1",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.12.0",
    "@types/suncalc": "^1.9.2",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^10.0.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.56.0",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,js}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
