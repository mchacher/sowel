# Database
SQLITE_PATH=./data/corbel.db

# Server
API_PORT=3000
API_HOST=0.0.0.0

# JWT Auth
JWT_SECRET=change-me-to-a-random-secret
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# Logging
LOG_LEVEL=info

# CORS
CORS_ORIGINS=http://localhost:5173

# Note: MQTT and Zigbee2MQTT settings are configured from the UI
# (Administration > Integrations), not from environment variables.
