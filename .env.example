# Winch — all settings are optional (sensible defaults built-in)

# Database
# SQLITE_PATH=./data/winch.db

# Server
# API_PORT=3000
# API_HOST=0.0.0.0

# JWT Auth — secret is auto-generated on first launch (persisted in data/.jwt-secret)
# JWT_SECRET=override-only-if-needed
# JWT_ACCESS_TTL=900
# JWT_REFRESH_TTL=2592000

# Logging
# LOG_LEVEL=info

# CORS — defaults to * (all origins)
# CORS_ORIGINS=http://localhost:5173

# Note: MQTT and Zigbee2MQTT settings are configured from the UI
# (Administration > Integrations), not from environment variables.
